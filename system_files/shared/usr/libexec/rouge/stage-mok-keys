#!/bin/bash
set -euo pipefail
shopt -s nullglob

PASSWORD="rouge"

for key in /etc/pki/akmods/certs/rouge_*.der; do
    if mokutil --test-key "$key" 2>/dev/null | grep -q "is already enrolled"; then
        continue
    fi

    fp=$(openssl x509 -in "$key" -inform DER -noout -fingerprint -sha256 2>/dev/null | cut -d= -f2 || true)
    if [[ -n "$fp" ]] && mokutil --list-new 2>/dev/null | grep -qF "$fp"; then
        continue
    fi

    printf '%s\n%s\n' "$PASSWORD" "$PASSWORD" | mokutil --import "$key" || true
done
